    "# ============================================
",
    "# CELLA 3: Carica dataset CSV
",
    "# ============================================
",
    "
",
    "import pandas as pd
",
    "from pathlib import Path
",
    "
",
    "# OPZIONE A: Dataset da Drive (consigliato)
",
    "CSV_PATH = "/content/drive/MyDrive/protoforge/protoforge_train_5k.csv"  # Modifica se diverso
",
    "
",
    "# OPZIONE B: Upload manuale (se non hai Drive)
",
    "# CSV_PATH = "/content/protoforge_train_5k.csv"
",
    "# from google.colab import files
",
    "# uploaded = files.upload()  # Upload manuale
",
    "
",
    "if Path(CSV_PATH).exists():
",
    "    df = pd.read_csv(CSV_PATH)
",
    "    print(f"✅ Dataset caricato: {len(df)} campioni")
",
    "    print(f"   Colonne: {list(df.columns)}")
",
    "    print(f"\n   Primi esempi:")
",
    "    print(df.head(2)[['domain', 'natural_language']].to_string())
",
    "else:
",
    "    print(f"❌ File non trovato: {CSV_PATH}")
",
    "    print("   Carica il CSV su Drive o usa upload manuale")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================
",
    "# CELLA 4: Configurazione training
",
    "# ============================================
",
    "
",
    "CONFIG = {
",
    "    "base_model": "Salesforce/codet5-small",
",
    "    "output_dir": "/content/drive/MyDrive/protoforge/output",
",
    "    "checkpoint_dir": "/content/drive/MyDrive/protoforge/checkpoints",
",
    "    "epochs": 10,
",
    "    "batch_size": 16,        # Aumentato per T4 (16GB)
",
    "    "learning_rate": 5e-4,
",
    "    "lora_r": 16,
",
    "    "lora_alpha": 32,
",
    "    "max_length_nl": 128,
",
    "    "max_length_proto": 512,
",
    "    "save_steps": 200,       # Salva ogni 200 steps
",
    "    "eval_steps": 100,
",
    "    "logging_steps": 10,
",
    "    "warmup_steps": 100,
",
    "    "early_stopping_patience": 3,
",
    "    "fp16": True,            # Mixed precision per T4
",
    "    "gradient_accumulation_steps": 2,
",
    "}
",
    "
",
    "print("⚙️  Configurazione:")
",
    "for k, v in CONFIG.items():
",
    "    print(f"   {k}: {v}")
",
    "
",
    "# Crea cartelle
",
    "Path(CONFIG["output_dir"]).mkdir(parents=True, exist_ok=True)
",
    "Path(CONFIG["checkpoint_dir"]).mkdir(parents=True, exist_ok=True)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================
",
    "# CELLA 5: Definizione Dataset e Modello
",
    "# ============================================
",
    "
",
    "import torch
",
    "from torch.utils.data import Dataset
",
    "from transformers import (
",
    "    T5ForConditionalGeneration,
",
    "    T5Tokenizer,
",
    "    TrainingArguments,
",
    "    Trainer,
",
    "    DataCollatorForSeq2Seq,
",
    "    EarlyStoppingCallback
",
    ")
",
    "from peft import LoraConfig, get_peft_model, TaskType
",
    "from sklearn.model_selection import train_test_split
",
    "
",
    "class ProtoDataset(Dataset):
",
    "    def __init__(self, data, tokenizer, max_nl=128, max_proto=512):
",
    "        self.data = data
",
    "        self.tokenizer = tokenizer
",
    "        self.max_nl = max_nl
",
    "        self.max_proto = max_proto
",
    "    
",
    "    def __len__(self):
",
    "        return len(self.data)
",
    "    
",
    "    def __getitem__(self, idx):
",
    "        item = self.data[idx]
",
    "        input_text = f"generate proto: {item['natural_language']}"
",
    "        target_text = item['proto_code']
",
    "        
",
    "        inputs = self.tokenizer(
",
    "            input_text, max_length=self.max_nl, padding='max_length',
",
    "            truncation=True, return_tensors='pt'
",
    "        )
",
    "        targets = self.tokenizer(
",
    "            target_text, max_length=self.max_proto, padding='max_length',
",
    "            truncation=True, return_tensors='pt'
",
    "        )
",
    "        
",
    "        labels = targets['input_ids'].clone()
",
    "        labels[labels == self.tokenizer.pad_token_id] = -100
",
    "        
",
    "        return {
",
    "            'input_ids': inputs['input_ids'].squeeze(),
",
    "            'attention_mask': inputs['attention_mask'].squeeze(),
",
    "            'labels': labels.squeeze()
",
    "        }
",
    "
",
    "# Split train/val
",
    "if 'split' in df.columns:
",
    "    train_df = df[df['split'] == 'train']
",
    "    val_df = df[df['split'] == 'test']
",
    "else:
",
    "    train_df, val_df = train_test_split(df, test_size=0.2, random_state=42)
",
    "
",
    "train_data = train_df.to_dict('records')
",
    "val_data = val_df.to_dict('records')
",
    "
",
    "print(f"📚 Train: {len(train_data)}, Val: {len(val_data)}")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================
",
    "# CELLA 6: Inizializzazione Modello + LoRA
",
    "# ============================================
",
    "
",
    "print("🚀 Caricamento modello...")
",
    "
",
    "tokenizer = T5Tokenizer.from_pretrained(CONFIG["base_model"])
",
    "model = T5ForConditionalGeneration.from_pretrained(CONFIG["base_model"])
",
    "
",
    "# Applica LoRA
",
    "lora_config = LoraConfig(
",
    "    r=CONFIG["lora_r"],
",
    "    lora_alpha=CONFIG["lora_alpha"],
",
    "    target_modules=["q", "v", "k", "o"],
",
    "    lora_dropout=0.05,
",
    "    bias="none",
",
    "    task_type=TaskType.SEQ_2_SEQ_LM
",
    ")
",
    "model = get_peft_model(model, lora_config)
",
    "model = model.cuda()  # Sposta su GPU
",
    "
",
    "# Statistiche
",
    "total = sum(p.numel() for p in model.parameters())
",
    "trainable = sum(p.numel() for p in model.parameters() if p.requires_grad)
",
    "print(f"✅ Modello pronto!")
",
    "print(f"   Parametri totali: {total:,}")
",
    "print(f"   Trainabili: {trainable:,} ({100*trainable/total:.2f}%)")
",
    "print(f"   GPU: {torch.cuda.get_device_name(0)}")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================
",
    "# CELLA 7: Training Arguments
",
    "# ============================================
",
    "
",
    "training_args = TrainingArguments(
",
    "    output_dir=CONFIG["checkpoint_dir"],
",
    "    num_train_epochs=CONFIG["epochs"],
",
    "    per_device_train_batch_size=CONFIG["batch_size"],
",
    "    per_device_eval_batch_size=CONFIG["batch_size"],
",
    "    learning_rate=CONFIG["learning_rate"],
",
    "    warmup_steps=CONFIG["warmup_steps"],
",
    "    weight_decay=0.01,
",
    "    logging_dir=f"{CONFIG['output_dir']}/logs",
",
    "    logging_steps=CONFIG["logging_steps"],
",
    "    eval_strategy="steps",
",
    "    eval_steps=CONFIG["eval_steps"],
",
    "    save_strategy="steps",
",
    "    save_steps=CONFIG["save_steps"],
",
    "    save_total_limit=3,
",
    "    load_best_model_at_end=True,
",
    "    metric_for_best_model="eval_loss",
",
    "    greater_is_better=False,
",
    "    fp16=CONFIG["fp16"],
",
    "    gradient_accumulation_steps=CONFIG["gradient_accumulation_steps"],
",
    "    report_to=["tensorboard"],
",
    "    remove_unused_columns=False,
",
    "    dataloader_num_workers=2,
",
    ")
",
    "
",
    "print("⚙️  Training arguments configurati")
",
    "print(f"   Batch effettivo: {CONFIG['batch_size'] * CONFIG['gradient_accumulation_steps']}")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================
",
    "# CELLA 8: AVVIO TRAINING
",
    "# ============================================
",
    "# ⚠️ ATTENZIONE: Questa cella impiega ~2-3 ore su T4 per 5k campioni
",
    "# Non chiudere il browser! Usa l'anti-idle trick se necessario
",
    "
",
    "train_dataset = ProtoDataset(train_data, tokenizer, CONFIG["max_length_nl"], CONFIG["max_length_proto"])
",
    "val_dataset = ProtoDataset(val_data, tokenizer, CONFIG["max_length_nl"], CONFIG["max_length_proto"])
",
    "
",
    "data_collator = DataCollatorForSeq2Seq(tokenizer, model=model)
",
    "
",
    "trainer = Trainer(
",
    "    model=model,
",
    "    args=training_args,
",
    "    train_dataset=train_dataset,
",
    "    eval_dataset=val_dataset,
",
    "    data_collator=data_collator,
",
    "    callbacks=[EarlyStoppingCallback(early_stopping_patience=CONFIG["early_stopping_patience"])]
",
    ")
",
    "
",
    "print("🚀 INIZIO TRAINING!")
",
    "print(f"   Ora: {pd.Timestamp.now()}")
",
    "print(f"   Durata stimata: ~{len(train_data) * CONFIG['epochs'] / 1000:.1f} minuti")
",
    "print("   " + "="*50)
",
    "
",
    "trainer.train()
",
    "
",
    "print("\n" + "="*50)
",
    "print("✅ TRAINING COMPLETATO!")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================
",
    "# CELLA 9: Salva modello finale su Drive
",
    "# ============================================
",
    "
",
    "final_path = f"{CONFIG['output_dir']}/protoforge_final"
",
    "trainer.save_model(final_path)
",
    "tokenizer.save_pretrained(final_path)
",
    "
",
    "# Salva config
",
    "import json
",
    "with open(f"{final_path}/training_config.json", "w") as f:
",
    "    json.dump(CONFIG, f, indent=2)
",
    "
",
    "print(f"💾 Modello salvato su Drive:")
",
    "print(f"   {final_path}")
",
    "print("\n📂 Contenuto:")
",
    "for f in Path(final_path).iterdir():
",
    "    size = f.stat().st_size / 1024 / 1024
",
    "    print(f"   {f.name}: {size:.1f} MB")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================
",
    "# CELLA 10: Test rapido post-training
",
    "# ============================================
",
    "
",
    "model.eval()
",
    "
",
    "test_queries = [
",
    "    "Gestisci utenti con email e login",
",
    "    "Sistema ordini con prodotti e quantita",
",
    "    "API autenticazione con token JWT"
",
    "]
",
    "
",
    "print("🧪 Test post-training:\n")
",
    "for query in test_queries:
",
    "    inputs = tokenizer(f"generate proto: {query}", return_tensors="pt", max_length=128, truncation=True).cuda()
",
    "    
",
    "    with torch.no_grad():
",
    "        outputs = model.generate(**inputs, max_length=512, num_beams=4, early_stopping=True)
",
    "    
",
    "    proto = tokenizer.decode(outputs[0], skip_special_tokens=True)
",
    "    print(f"📝 {query}")
",
    "    print(f"⚙️  {proto[:200]}...\n")"
   ]
  },
